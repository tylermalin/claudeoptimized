# Claude Token Optimizer - Environment Configuration
# Copy this file to .env and fill in your values

# Required: Your Anthropic API Key
# Get it from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional: Analytics storage location
ANALYTICS_FILE=./token-analytics.json

# Optional: Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Cache settings
ENABLE_CACHE=true
CACHE_SIZE_LIMIT=100

# Optional: Streaming settings
ENABLE_STREAMING=true

# Optional: Batch processing settings
ENABLE_BATCHING=true
BATCH_TIMEOUT_MS=30000

# Optional: Model overrides (leave blank to use auto-selection)
# FORCE_MODEL=claude-haiku-4-5-20251001
# FORCE_MODEL=claude-sonnet-4-5-20250929
# FORCE_MODEL=claude-opus-4-5-20251101

# Optional: Rate limiting
MAX_REQUESTS_PER_MINUTE=100
MAX_TOKENS_PER_MINUTE=2000000

# Optional: Default parameters
DEFAULT_MAX_TOKENS=1024
DEFAULT_TEMPERATURE=0.7

# Optional: Custom settings
PROMPT_PREFIX=""
SYSTEM_PROMPT_PREFIX=""
